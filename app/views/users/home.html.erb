<html>
  <head>
    <style type="text/css">.turbo-progress-bar {
      position: fixed;
      display: block;
      top: 0;
      left: 0;
      height: 3px;
      background: #0076ff;
      z-index: 2147483647;
      transition:
        width 300ms ease-out,
        opacity 150ms 150ms ease-in;
      transform: translate3d(0, 0, 0);}
    </style>
    <title>Target: Delivery Tracker 1</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="csrf-param" content="authenticity_token">

    <meta name="csp-nonce">
  </head>

  <body>

    <nav>
      <a href="/users/home">Delivery Tracker</a>
        |
        <a href="/users/edit">Edit profile</a>
        |
        <a href="/users/sign_out">Sign out</a>
    </nav>

    <hr>

    <p>Welcome! You have signed up successfully.</p>


    <div>
      <div>
        <h1>
          Delivery Tracker
        </h1>

        <p>Know if something gets lost in the mail.</p>
      </div>
    </div>

    <hr>

    <div>
      <div>
        <h2>
          Expecting a package?
        </h2>

        <form action="/insert_delivery" method="post">
          <input type="hidden" id="user_id" value="<%= @uid %>">
          <div>
            <label for="description">
              Description
            </label>

            <input type="text" id="description" name="description">
          </div>

          <div>
            <label for="expected_on">
              Supposed to arrive on
            </label>

            <input type="date" id="expected_on" name="expected_on">
          </div>

          <div>
            <label for="details">
              Details
            </label>

            <textarea id="details" name="details" rows="3"></textarea>
          </div>

          <button>
            Log delivery
          </button>
        </form>
      </div>
    </div>

    <hr>

    <div class="waiting_on">
      <h2>Waiting on</h2>

      <ul>
      </ul>
    </div>

    <hr>

    <div class="received">
      <h2>Received</h2>

      <ul>
      </ul>
    </div>
  </body>
  <grammarly-desktop-integration data-grammarly-shadow-root="true"></grammarly-desktop-integration>
</html>
